#!/usr/bin/env python3
"""agent-session: persistent multi-turn LLM session abstraction over heterogeneous backend CLIs.

Verbs: doctor, list-backends, describe, spawn, run, send, status, output, tldr, cleanup.
"""

from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
import time
import uuid
from abc import ABC, abstractmethod
from contextlib import contextmanager
from pathlib import Path
from typing import Optional


# ============================================================
# State
# ============================================================

DEFAULT_STATE_DIR = Path.home() / ".cache" / "agent-session"
DEFAULT_TIMEOUT = 600  # seconds


def state_root(state_dir: Optional[str]) -> Path:
    return Path(state_dir) if state_dir else DEFAULT_STATE_DIR


def session_dir(role_id: str, state_dir: Optional[str]) -> Path:
    return state_root(state_dir) / role_id


def read_meta(role_id: str, state_dir: Optional[str]) -> Optional[dict]:
    p = session_dir(role_id, state_dir) / "meta.json"
    if not p.exists():
        return None
    return json.loads(p.read_text())


def write_meta(role_id: str, state_dir: Optional[str], meta: dict) -> None:
    d = session_dir(role_id, state_dir)
    d.mkdir(parents=True, exist_ok=True)
    (d / "meta.json").write_text(json.dumps(meta, indent=2))


def append_log(role_id: str, state_dir: Optional[str], msg: str) -> None:
    d = session_dir(role_id, state_dir)
    d.mkdir(parents=True, exist_ok=True)
    with (d / "log").open("a") as f:
        f.write(f"[{time.strftime('%Y-%m-%dT%H:%M:%S')}] {msg}\n")


@contextmanager
def lock(role_id: str, state_dir: Optional[str]):
    """fail-fast lock; rejects concurrent operations on the same role-id."""
    d = session_dir(role_id, state_dir)
    d.mkdir(parents=True, exist_ok=True)
    lf = d / ".lock"
    if lf.exists():
        raise RuntimeError(f"role busy: {role_id} (lock at {lf})")
    lf.write_text(str(os.getpid()))
    try:
        yield
    finally:
        lf.unlink(missing_ok=True)


def _extract_tldr_and_stance(text: str) -> dict:
    """Extract debate's TL;DR section and stance tag from a role's latest output.

    Returns {"tldr_text": str | None, "stance": str | None}.
    `tldr_text` is the content between '## TL;DR' (exclusive of the header line)
    and the next '## ' heading or end-of-text, with any trailing whitelisted stance
    tag (`[stance: hold|concede|add]`) stripped, then trimmed.
    `stance` is one of 'hold' | 'concede' | 'add' if a `[stance: <word>]` tag
    is present anywhere in the text with a whitelisted value; None otherwise.
    Note: invalid stance values (e.g. `[stance: maybe]`) stay in `tldr_text` —
    the helper does not try to clean malformed output.
    """
    if not text:
        return {"tldr_text": None, "stance": None}
    # Match the section starting with '## TL;DR' until the next '## ' or end.
    tldr_match = re.search(
        r"^## TL;DR[^\n]*\n(.*?)(?=^## |\Z)",
        text,
        re.MULTILINE | re.DOTALL,
    )
    tldr_text = tldr_match.group(1).strip() if tldr_match else None
    # Remove any trailing stance tag line from tldr_text, then trim again
    if tldr_text:
        tldr_text = re.sub(r'\n?\[stance:\s*(hold|concede|add)\s*\]\s*$', '', tldr_text)
        tldr_text = tldr_text.strip()
    stance_match = re.search(
        r"\[stance:\s*(hold|concede|add)\s*\]",
        text,
    )
    stance = stance_match.group(1) if stance_match else None
    return {"tldr_text": tldr_text, "stance": stance}


# ============================================================
# Driver interface
# ============================================================


class Driver(ABC):
    name: str
    binary_family: str  # anthropic | openai | google | local | unknown — supply-chain identity (which CLI binary)

    # default model→family lookup table used by model_family() unless a driver overrides
    MODEL_FAMILY_PREFIXES: dict[str, str] = {
        "anthropic": "anthropic",
        "claude": "anthropic",
        "openai": "openai",
        "gpt": "openai",
        "google": "google",
        "gemini": "google",
        "models/gemini": "google",
        "xai": "xai",
        "grok": "xai",
    }

    @classmethod
    def model_family(cls, model: Optional[str]) -> str:
        """Resolve request-routing family from a model string.

        Falls back to cls.binary_family when the model is null or its prefix
        is unrecognized — *never* returns "unknown" for a recognized backend's
        default model (that would silently break debate's cross-family logic).
        """
        if not model:
            return cls.binary_family
        # Try slash-namespaced first ("anthropic/claude-opus" → "anthropic")
        prefix = model.split("/", 1)[0]
        if prefix in cls.MODEL_FAMILY_PREFIXES:
            return cls.MODEL_FAMILY_PREFIXES[prefix]
        # Try first dash-segment ("claude-3-opus" → "claude" → "anthropic", "gpt-4" → "gpt" → "openai")
        head = model.split("-", 1)[0].split("/")[-1].lower()
        return cls.MODEL_FAMILY_PREFIXES.get(head, cls.binary_family)

    @classmethod
    @abstractmethod
    def detect(cls) -> Optional[str]:
        """Return path to the backend CLI if available, else None."""

    @abstractmethod
    def spawn(
        self,
        role_id: str,
        prompt_file: str,
        model: Optional[str],
        state_dir: Optional[str],
        system_prompt: Optional[str],
        cwd: Optional[str],
        yolo: bool,
    ) -> None: ...

    @abstractmethod
    def send(self, role_id: str, prompt_file: str, state_dir: Optional[str]) -> None: ...

    @abstractmethod
    def status(
        self,
        role_id: str,
        state_dir: Optional[str],
        wait: bool,
        timeout: Optional[int],
    ) -> str: ...

    @abstractmethod
    def cleanup(self, role_id: str, state_dir: Optional[str]) -> None: ...

    @abstractmethod
    def run(
        self,
        prompt_file: str,
        model: Optional[str],
        system_prompt: Optional[str],
        cwd: Optional[str],
        yolo: bool,
    ) -> str:
        """One-shot, stateless invocation. Returns assistant text directly.
        No state dir writes. Caller does not pass role-id. Each driver is
        responsible for cleaning up any backend-side session it creates.
        """
        ...


# ============================================================
# Claude driver
# ============================================================


class ClaudeDriver(Driver):
    name = "claude"
    binary_family = "anthropic"

    @classmethod
    def detect(cls) -> Optional[str]:
        return shutil.which("claude")

    def spawn(self, role_id, prompt_file, model, state_dir, system_prompt, cwd, yolo):
        sd = session_dir(role_id, state_dir)
        (sd / "input").mkdir(parents=True, exist_ok=True)
        (sd / "output").mkdir(parents=True, exist_ok=True)

        sid = str(uuid.uuid4())

        r0_in = sd / "input" / "r0.md"
        shutil.copy(prompt_file, r0_in)

        cmd = ["claude", "-p", "--session-id", sid]
        if model:
            cmd += ["--model", model]
        if system_prompt:
            cmd += ["--system-prompt", system_prompt]
        if yolo:
            cmd += ["--dangerously-skip-permissions"]

        meta = {
            "backend": "claude",
            "model": model or "default",
            "sid": sid,
            "round_count": 0,
            "state": "spawning",
            "system_prompt": system_prompt,
            "cwd": cwd,
            "yolo": yolo,
        }
        write_meta(role_id, state_dir, meta)

        with r0_in.open() as f:
            result = subprocess.run(
                cmd, stdin=f, capture_output=True, text=True, timeout=DEFAULT_TIMEOUT,
                cwd=cwd,
            )

        (sd / "output" / "r0.txt").write_text(result.stdout)
        if result.returncode != 0:
            append_log(role_id, state_dir, f"spawn rc={result.returncode}\nstderr:\n{result.stderr}")
            meta["state"] = "failed"
            write_meta(role_id, state_dir, meta)
            raise RuntimeError(f"claude spawn failed (rc={result.returncode}): {result.stderr.strip()}")

        meta["round_count"] = 1
        meta["state"] = "active"
        write_meta(role_id, state_dir, meta)

    def send(self, role_id, prompt_file, state_dir):
        sd = session_dir(role_id, state_dir)
        meta = read_meta(role_id, state_dir)
        if not meta:
            raise RuntimeError(f"session not found: {role_id}")
        if meta["state"] != "active":
            raise RuntimeError(f"session not active: {role_id} (state={meta['state']})")

        n = meta["round_count"]  # next round index
        rN_in = sd / "input" / f"r{n}.md"
        shutil.copy(prompt_file, rN_in)

        cmd = ["claude", "-p", "--resume", meta["sid"]]
        if meta.get("model") and meta["model"] != "default":
            cmd += ["--model", meta["model"]]
        if meta.get("yolo", False):
            cmd += ["--dangerously-skip-permissions"]

        with rN_in.open() as f:
            result = subprocess.run(
                cmd, stdin=f, capture_output=True, text=True, timeout=DEFAULT_TIMEOUT,
                cwd=meta.get("cwd"),
            )

        (sd / "output" / f"r{n}.txt").write_text(result.stdout)
        if result.returncode != 0:
            append_log(role_id, state_dir, f"send r{n} rc={result.returncode}\nstderr:\n{result.stderr}")
            meta["state"] = "error"
            write_meta(role_id, state_dir, meta)
            raise RuntimeError(f"claude send failed (rc={result.returncode}): {result.stderr.strip()}")

        meta["round_count"] = n + 1
        write_meta(role_id, state_dir, meta)

    def status(self, role_id, state_dir, wait, timeout):
        # Claude driver runs synchronously in spawn/send, so status reflects last completed call.
        meta = read_meta(role_id, state_dir)
        if not meta:
            return "error"
        return {"spawning": "running", "active": "done", "failed": "error", "error": "error"}.get(
            meta["state"], "error"
        )

    def cleanup(self, role_id, state_dir):
        sd = session_dir(role_id, state_dir)
        if not sd.exists():
            return
        meta = read_meta(role_id, state_dir)
        if meta and meta.get("sid"):
            sid = meta["sid"]
            projects = Path.home() / ".claude" / "projects"
            if projects.exists():
                for f in projects.rglob(f"{sid}.jsonl"):
                    f.unlink(missing_ok=True)
                for d in projects.rglob(sid):
                    if d.is_dir():
                        shutil.rmtree(d, ignore_errors=True)
        shutil.rmtree(sd, ignore_errors=True)

    def run(self, prompt_file, model, system_prompt, cwd, yolo):
        cmd = ["claude", "-p"]
        if model:
            cmd += ["--model", model]
        if system_prompt:
            cmd += ["--system-prompt", system_prompt]
        if yolo:
            cmd += ["--dangerously-skip-permissions"]
        with open(prompt_file) as f:
            result = subprocess.run(
                cmd, stdin=f, capture_output=True, text=True, timeout=DEFAULT_TIMEOUT,
                cwd=cwd,
            )
        if result.returncode != 0:
            raise RuntimeError(f"claude run failed (rc={result.returncode}): {result.stderr.strip()}")
        return result.stdout


# ============================================================
# Opencode driver
# ============================================================


class OpencodeDriver(Driver):
    name = "opencode"
    # binary_family = "openai" is a fallback; opencode is multi-provider, so the actual
    # request-routing family is computed per spawn from the chosen --model via Driver.model_family().
    binary_family = "openai"

    @classmethod
    def detect(cls) -> Optional[str]:
        return shutil.which("opencode")

    def _opencode(self) -> str:
        path = self.detect()
        if not path:
            raise RuntimeError("opencode not found; install opencode (https://opencode.ai/docs/install)")
        return path

    # Substrings that indicate the configured opencode model is unavailable
    # for the current auth — surfaces with an actionable hint instead of leaking
    # raw API error text.
    _MODEL_AUTH_HINTS: tuple[str, ...] = (
        "is not supported when using",
        "ProviderModelNotFoundError",
        "Model not found",
        "401",
        "unauthorized",
    )

    @staticmethod
    def _parse_run_output(stdout: str) -> tuple[Optional[str], str]:
        """Parse `opencode run --format json` NDJSON. Returns (sessionID, assistant_text).

        Raises RuntimeError on:
        - explicit `type:"error"` events (with a `--model` hint when the failure
          looks like a model-availability/auth problem)
        - empty assistant text (no `type:"text"` events with non-empty `part.text`)
          — typically means the agent entered a tool-loop, hit a quota, or got
          silently rejected; sid may be set but state is not "active".
        """
        sid: Optional[str] = None
        chunks: list[str] = []
        for line in stdout.splitlines():
            line = line.strip()
            if not line or not line.startswith("{"):
                continue
            try:
                ev = json.loads(line)
            except json.JSONDecodeError:
                continue
            if sid is None and ev.get("sessionID"):
                sid = ev["sessionID"]
            if ev.get("type") == "text":
                part = ev.get("part") or {}
                text = part.get("text")
                if text:
                    chunks.append(text)
            elif ev.get("type") == "error":
                err = ev.get("error") or {}
                msg = (err.get("data") or {}).get("message") or err.get("name") or "unknown error"
                # Model-availability / auth issue → suggest --model override.
                if any(h.lower() in msg.lower() for h in OpencodeDriver._MODEL_AUTH_HINTS):
                    raise RuntimeError(
                        f"opencode model rejected: {msg}\n"
                        "  Hint: opencode's default model is not usable with this auth. "
                        "Retry with `--model <provider>/<model>` (e.g. `openai/gpt-5.4-mini`), "
                        "or set `model` for this backend in ~/.config/agents/debate/prefs.json."
                    )
                raise RuntimeError(f"opencode run error: {msg}")
        if not chunks:
            raise RuntimeError(
                "opencode produced no assistant text — likely tool-loop, quota, or silent "
                "rejection (rc=0 but no text events). "
                "Check `opencode auth list` and the configured agent; consider `--model <model>` "
                "to bypass the default."
            )
        return sid, "".join(chunks)

    def _run(self, role_id, state_dir, prompt_text, *, session: Optional[str], model: Optional[str], cwd: Optional[str] = None, yolo: bool = False):
        cmd = [self._opencode(), "run", prompt_text, "--format", "json"]
        if session:
            cmd += ["--session", session]
        else:
            cmd += ["--title", f"agent-session-{role_id or 'run'}"]
        if model:
            cmd += ["-m", model]
        if cwd:
            cmd += ["--dir", cwd]
        if yolo:
            cmd += ["--dangerously-skip-permissions"]
        agent_env = os.environ.get("OPENCODE_AGENT")
        if agent_env:
            cmd += ["--agent", agent_env]
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=DEFAULT_TIMEOUT)
        if result.returncode != 0:
            if role_id is not None:
                append_log(role_id, state_dir, f"opencode run rc={result.returncode}\nstderr:\n{result.stderr}\nstdout:\n{result.stdout}")
            raise RuntimeError(f"opencode run failed (rc={result.returncode}): {result.stderr.strip() or result.stdout.strip()[:300]}")
        return self._parse_run_output(result.stdout)

    def spawn(self, role_id, prompt_file, model, state_dir, system_prompt, cwd, yolo):
        sd = session_dir(role_id, state_dir)
        (sd / "input").mkdir(parents=True, exist_ok=True)
        (sd / "output").mkdir(parents=True, exist_ok=True)

        # opencode has no separate system-prompt flag — prepend if given.
        prompt_content = Path(prompt_file).read_text()
        if system_prompt:
            prompt_content = f"<system>\n{system_prompt}\n</system>\n\n{prompt_content}"
        r0_in = sd / "input" / "r0.md"
        r0_in.write_text(prompt_content)

        meta = {
            "backend": "opencode",
            "model": model or "default",
            "sid": None,
            "round_count": 0,
            "state": "spawning",
            "system_prompt": system_prompt,
            "cwd": cwd,
            "yolo": yolo,
        }
        write_meta(role_id, state_dir, meta)

        try:
            sid, text = self._run(role_id, state_dir, prompt_content, session=None, model=model, cwd=cwd, yolo=yolo)
        except RuntimeError:
            meta["state"] = "failed"
            write_meta(role_id, state_dir, meta)
            raise
        if not sid:
            meta["state"] = "failed"
            write_meta(role_id, state_dir, meta)
            raise RuntimeError("opencode run produced no sessionID — check stdout JSON shape")

        (sd / "output" / "r0.txt").write_text(text)
        meta["sid"] = sid
        meta["round_count"] = 1
        meta["state"] = "active"
        write_meta(role_id, state_dir, meta)

    def send(self, role_id, prompt_file, state_dir):
        sd = session_dir(role_id, state_dir)
        meta = read_meta(role_id, state_dir)
        if not meta:
            raise RuntimeError(f"session not found: {role_id}")
        if meta["state"] != "active":
            raise RuntimeError(f"session not active: {role_id} (state={meta['state']})")

        n = meta["round_count"]
        rN_in = sd / "input" / f"r{n}.md"
        shutil.copy(prompt_file, rN_in)

        model = meta.get("model")
        if model == "default":
            model = None
        try:
            _, text = self._run(
                role_id,
                state_dir,
                rN_in.read_text(),
                session=meta["sid"],
                model=model,
                cwd=meta.get("cwd"),
                yolo=meta.get("yolo", False),
            )
        except RuntimeError:
            meta["state"] = "error"
            write_meta(role_id, state_dir, meta)
            raise

        (sd / "output" / f"r{n}.txt").write_text(text)
        meta["round_count"] = n + 1
        write_meta(role_id, state_dir, meta)

    def status(self, role_id, state_dir, wait, timeout):
        meta = read_meta(role_id, state_dir)
        if not meta:
            return "error"
        return {"spawning": "running", "active": "done", "failed": "error", "error": "error"}.get(
            meta["state"], "error"
        )

    def cleanup(self, role_id, state_dir):
        sd = session_dir(role_id, state_dir)
        if not sd.exists():
            return
        meta = read_meta(role_id, state_dir)
        if meta and meta.get("sid"):
            try:
                subprocess.run(
                    [self._opencode(), "session", "delete", meta["sid"]],
                    capture_output=True, text=True, timeout=60,
                )
            except Exception as e:
                append_log(role_id, state_dir, f"cleanup opencode session delete failed: {e}")
        shutil.rmtree(sd, ignore_errors=True)

    def run(self, prompt_file, model, system_prompt, cwd, yolo):
        prompt_content = Path(prompt_file).read_text()
        if system_prompt:
            prompt_content = f"<system>\n{system_prompt}\n</system>\n\n{prompt_content}"
        sid, text = self._run(
            role_id=None,
            state_dir=None,
            prompt_text=prompt_content,
            session=None,
            model=model,
            cwd=cwd,
            yolo=yolo,
        )
        if sid:
            try:
                subprocess.run(
                    [self._opencode(), "session", "delete", sid],
                    capture_output=True, text=True, timeout=30,
                )
            except Exception:
                pass
        return text


# ============================================================
# Codex driver
# ============================================================


class CodexDriver(Driver):
    name = "codex"
    binary_family = "openai"

    @classmethod
    def detect(cls) -> Optional[str]:
        return shutil.which("codex")

    def _session_cwd(self, role_id: str, state_dir: Optional[str]) -> Path:
        """Each role gets an isolated cwd so `codex exec resume --last` is unambiguous.
        Always returns an absolute path so subsequent commands don't get confused by
        relative-path interactions with subprocess `cwd=` and `--cd`."""
        cwd = session_dir(role_id, state_dir) / "cwd"
        cwd.mkdir(parents=True, exist_ok=True)
        return cwd.resolve()

    def _common_flags(self, yolo: bool = False) -> list[str]:
        # Non-interactive: bypass approvals; sandbox read-only so a role can't damage the host
        flags = ["--full-auto", "--skip-git-repo-check"]
        if yolo:
            flags.append("--dangerously-bypass-approvals-and-sandbox")
        return flags

    def spawn(self, role_id, prompt_file, model, state_dir, system_prompt, cwd, yolo):
        sd = session_dir(role_id, state_dir)
        (sd / "input").mkdir(parents=True, exist_ok=True)
        (sd / "output").mkdir(parents=True, exist_ok=True)

        session_cwd = Path(cwd).resolve() if cwd else self._session_cwd(role_id, state_dir)

        # Compose prompt (codex has no separate system-prompt flag — prepend if given)
        prompt_content = Path(prompt_file).read_text()
        if system_prompt:
            prompt_content = f"<system>\n{system_prompt}\n</system>\n\n{prompt_content}"

        r0_in = sd / "input" / "r0.md"
        r0_in.write_text(prompt_content)
        r0_out = sd / "output" / "r0.txt"

        meta = {
            "backend": "codex",
            "model": model or "default",
            "sid": None,  # not needed — cwd-scoped --last finds it
            "round_count": 0,
            "state": "spawning",
            "system_prompt": system_prompt,
            "cwd": str(session_cwd),
            "yolo": yolo,
        }
        write_meta(role_id, state_dir, meta)

        # spawn: use --cd (codex exec supports it). Don't also set subprocess cwd= or
        # codex would try to resolve the same path twice.
        cmd = ["codex", "exec", *self._common_flags(yolo),
               "--cd", str(session_cwd),
               "--output-last-message", str(r0_out.resolve())]
        if model:
            cmd += ["-m", model]

        result = subprocess.run(
            cmd, input=prompt_content, capture_output=True, text=True, timeout=DEFAULT_TIMEOUT,
        )
        if result.returncode != 0:
            append_log(role_id, state_dir, f"spawn rc={result.returncode}\nstderr:\n{result.stderr}")
            meta["state"] = "failed"
            write_meta(role_id, state_dir, meta)
            raise RuntimeError(f"codex exec failed (rc={result.returncode}): {result.stderr.strip()}")

        if not r0_out.exists() or r0_out.stat().st_size == 0:
            append_log(role_id, state_dir, f"spawn empty output\nstdout:\n{result.stdout}")
            meta["state"] = "error"
            write_meta(role_id, state_dir, meta)
            raise RuntimeError("codex exec produced no output")

        meta["round_count"] = 1
        meta["state"] = "active"
        write_meta(role_id, state_dir, meta)

    def send(self, role_id, prompt_file, state_dir):
        sd = session_dir(role_id, state_dir)
        meta = read_meta(role_id, state_dir)
        if not meta:
            raise RuntimeError(f"session not found: {role_id}")
        if meta["state"] != "active":
            raise RuntimeError(f"session not active: {role_id} (state={meta['state']})")

        n = meta["round_count"]
        rN_in = sd / "input" / f"r{n}.md"
        shutil.copy(prompt_file, rN_in)
        rN_out = sd / "output" / f"r{n}.txt"

        cwd = Path(meta.get("cwd") or self._session_cwd(role_id, state_dir))

        # send: `codex exec resume` does NOT accept --cd; use subprocess cwd= so that
        # `--last` resolves to the session created in this exact directory by spawn.
        prompt_content = rN_in.read_text()
        cmd = ["codex", "exec", "resume", "--last", *self._common_flags(meta.get("yolo", False)),
               "--output-last-message", str(rN_out.resolve())]
        if meta.get("model") and meta["model"] != "default":
            cmd += ["-m", meta["model"]]

        result = subprocess.run(
            cmd, input=prompt_content, capture_output=True, text=True,
            cwd=str(cwd), timeout=DEFAULT_TIMEOUT,
        )
        if result.returncode != 0:
            append_log(role_id, state_dir, f"send r{n} rc={result.returncode}\nstderr:\n{result.stderr}")
            meta["state"] = "error"
            write_meta(role_id, state_dir, meta)
            raise RuntimeError(f"codex exec resume failed (rc={result.returncode}): {result.stderr.strip()}")

        if not rN_out.exists() or rN_out.stat().st_size == 0:
            raise RuntimeError("codex exec resume produced no output")

        meta["round_count"] = n + 1
        write_meta(role_id, state_dir, meta)

    def status(self, role_id, state_dir, wait, timeout):
        meta = read_meta(role_id, state_dir)
        if not meta:
            return "error"
        return {"spawning": "running", "active": "done", "failed": "error", "error": "error"}.get(
            meta["state"], "error"
        )

    def cleanup(self, role_id, state_dir):
        sd = session_dir(role_id, state_dir)
        if not sd.exists():
            return
        # codex sessions live under ~/.codex/sessions or similar; we don't reach in to delete them
        # (they get GC'd by codex itself or stay harmless). Just nuke our state dir.
        shutil.rmtree(sd, ignore_errors=True)

    def run(self, prompt_file, model, system_prompt, cwd, yolo):
        raise NotImplementedError(
            "codex driver `run()` not implemented yet — "
            "this jam (agent-session-generic-entry) ships opencode + claude only. "
            "Track in a follow-up issue."
        )


# ============================================================
# Registry
# ============================================================


DRIVERS: list[type[Driver]] = [ClaudeDriver, OpencodeDriver, CodexDriver]


def get_driver_for_backend(name: str) -> Optional[type[Driver]]:
    return next((d for d in DRIVERS if d.name == name), None)


def get_driver_for_session(role_id: str, state_dir: Optional[str]) -> Optional[Driver]:
    meta = read_meta(role_id, state_dir)
    if not meta:
        return None
    cls = get_driver_for_backend(meta["backend"])
    return cls() if cls else None


# ============================================================
# Commands
# ============================================================


def _probe_auth(driver_name: str) -> tuple[Optional[bool], Optional[str]]:
    """Lightweight auth check per backend. Returns (ok, identity).

    `ok` is None when we can't tell (no probe wired up); True/False otherwise.
    `identity` is a free-form string like "anthropic-api" / "openai-chatgpt" /
    "openai-api" used by debate's pool-collapse warning to spot collisions where
    distinct binaries share an upstream provider/account.
    """
    try:
        if driver_name == "claude":
            # File-based on Linux / older versions
            cred = Path.home() / ".claude" / ".credentials.json"
            if cred.exists():
                return True, "anthropic-api"
            # Modern Claude Code on macOS stores creds in the OS Keychain — there's no
            # file to stat, so we fall back to inferring auth from prior usage:
            projects = Path.home() / ".claude" / "projects"
            if projects.exists() and any(projects.iterdir()):
                return True, "anthropic-api"
            return None, None  # genuinely uncertain — don't claim "missing"
        if driver_name == "opencode":
            r = subprocess.run(
                ["opencode", "auth", "list"], capture_output=True, text=True, timeout=10
            )
            if r.returncode != 0 or not r.stdout.strip():
                return False, None
            text = r.stdout.lower()
            if "oauth" in text or "chatgpt" in text:
                return True, "openai-chatgpt"
            if "anthropic" in text:
                return True, "anthropic-api"
            if "openai" in text:
                return True, "openai-api"
            return True, "opencode-other"
        if driver_name == "codex":
            auth = Path.home() / ".codex" / "auth.json"
            if not auth.exists():
                return False, None
            try:
                data = json.loads(auth.read_text())
            except Exception:
                return True, "openai-api"
            mode = (data.get("mode") or data.get("auth_mode") or "").lower()
            if "chatgpt" in mode or "oauth" in mode:
                return True, "openai-chatgpt"
            return True, "openai-api"
    except Exception:
        return None, None
    return None, None


def cmd_doctor(args) -> int:
    print("Detected backends:")
    available: list[type[Driver]] = []
    auth_identities: list[str] = []
    for d in DRIVERS:
        path = d.detect()
        if not path:
            print(f"  ✗ {d.name:<10} not installed  — see references/backend-{d.name}.md")
            continue
        available.append(d)
        ok, identity = _probe_auth(d.name)
        if ok is True:
            auth_label = f"auth={identity}"
            auth_identities.append(identity)
        elif ok is False:
            auth_label = "auth=missing — run login"
        else:
            auth_label = "auth=?"
        print(f"  ✓ {d.name:<10} {path:<40}  family={d.binary_family:<10} {auth_label}")
    binary_families = {d.binary_family for d in available}
    print()
    print(f"Available backends: {len(available)}")
    print(
        f"Distinct binary families: {len(binary_families)}"
        + (f" ({', '.join(sorted(binary_families))})" if binary_families else "")
    )
    distinct_auths = set(auth_identities)
    if len(distinct_auths) >= 2:
        print(f"Distinct auth identities: {len(distinct_auths)} ({', '.join(sorted(distinct_auths))})")
    elif distinct_auths:
        print(
            f"Auth-identity collision: all detected backends share '{next(iter(distinct_auths))}' — "
            "cross-family is notional, not actual"
        )
    if len(binary_families) >= 2:
        print("Multi-model capability: ✓")
    else:
        print("Multi-model capability: ✗ (need ≥2 distinct families for cross-model debate)")
    return 0


def cmd_list_backends(args) -> int:
    for d in DRIVERS:
        if d.detect():
            print(d.name)
    return 0


def cmd_describe(args) -> int:
    meta = read_meta(args.role_id, args.state_dir)
    if not meta:
        print(f"session not found: {args.role_id}", file=sys.stderr)
        return 2
    backend = meta.get("backend")
    cls = get_driver_for_backend(backend) if backend else None
    model = meta.get("model")
    if model == "default":
        model = None
    binary_family = cls.binary_family if cls else None
    model_family = cls.model_family(model) if cls else None
    out = {
        "role_id": args.role_id,
        "backend": backend,
        "binary_family": binary_family,
        "model_family": model_family,
        "model": meta.get("model"),
        "round_count": meta.get("round_count", 0),
        "state": meta.get("state"),
    }
    print(json.dumps(out, indent=2))
    return 0


def cmd_spawn(args) -> int:
    sd = session_dir(args.role_id, args.state_dir)
    if sd.exists() and not args.force:
        print(f"session already exists: {args.role_id} (use --force to overwrite)", file=sys.stderr)
        return 2
    if sd.exists() and args.force:
        shutil.rmtree(sd, ignore_errors=True)

    cls = get_driver_for_backend(args.backend)
    if not cls:
        print(f"unknown backend: {args.backend} (run `agent-session list-backends`)", file=sys.stderr)
        return 2
    if not cls.detect():
        print(f"backend not installed: {args.backend} — see references/backend-{args.backend}.md", file=sys.stderr)
        return 2

    with lock(args.role_id, args.state_dir):
        cls().spawn(
            args.role_id,
            args.prompt_file,
            args.model,
            args.state_dir,
            args.system_prompt,
            args.cwd,
            args.yolo,
        )
    return 0


def cmd_run(args) -> int:
    """One-shot stateless invocation. Returns assistant text to stdout."""
    cls = get_driver_for_backend(args.backend)
    if not cls:
        print(f"unknown backend: {args.backend} (run `agent-session list-backends`)", file=sys.stderr)
        return 2
    if not cls.detect():
        print(f"backend not installed: {args.backend} — see references/backend-{args.backend}.md", file=sys.stderr)
        return 2

    text = cls().run(
        args.prompt_file,
        args.model,
        args.system_prompt,
        args.cwd,
        args.yolo,
    )
    sys.stdout.write(text)
    if not text.endswith("\n"):
        sys.stdout.write("\n")
    return 0


def cmd_send(args) -> int:
    drv = get_driver_for_session(args.role_id, args.state_dir)
    if not drv:
        print(f"session not found: {args.role_id}", file=sys.stderr)
        return 2
    with lock(args.role_id, args.state_dir):
        drv.send(args.role_id, args.prompt_file, args.state_dir)
    return 0


def cmd_status(args) -> int:
    drv = get_driver_for_session(args.role_id, args.state_dir)
    if not drv:
        print("error")
        return 0
    # All current drivers are synchronous (spawn/send block until done), so status
    # is a pure read of meta.json — no wait/timeout polling.
    print(drv.status(args.role_id, args.state_dir, False, None))
    return 0


def cmd_output(args) -> int:
    sd = session_dir(args.role_id, args.state_dir)
    meta = read_meta(args.role_id, args.state_dir)
    if not meta:
        print(f"session not found: {args.role_id}", file=sys.stderr)
        return 2
    n = args.round if args.round is not None else meta["round_count"] - 1
    f = sd / "output" / f"r{n}.txt"
    if not f.exists():
        print(f"output round not found: r{n}", file=sys.stderr)
        return 2
    sys.stdout.write(f.read_text())
    return 0


def cmd_tldr(args) -> int:
    """Return JSON {role_id, round_count, tldr_text, stance} for the latest round.

    Owned format knowledge: `## TL;DR` / `[stance: hold|concede|add]` come from debate's
    output schema (see references in debate/SKILL.md). Centralized here so consumers
    don't reimplement extraction.
    """
    sd = session_dir(args.role_id, args.state_dir)
    meta = read_meta(args.role_id, args.state_dir)
    if not meta:
        print(json.dumps({"error": "session not found", "role_id": args.role_id}), file=sys.stderr)
        return 2
    n = args.round if args.round is not None else meta["round_count"] - 1
    f = sd / "output" / f"r{n}.txt"
    if not f.exists():
        print(json.dumps({"error": "output round not found", "role_id": args.role_id, "round": n}), file=sys.stderr)
        return 2
    text = f.read_text()
    if not text.strip():
        print(json.dumps({"error": "empty output", "role_id": args.role_id, "round": n}), file=sys.stderr)
        return 2
    extracted = _extract_tldr_and_stance(text)
    print(json.dumps({
        "role_id": args.role_id,
        "round_count": meta.get("round_count", 0),
        "tldr_text": extracted["tldr_text"],
        "stance": extracted["stance"],
    }))
    return 0


def cmd_cleanup(args) -> int:
    drv = get_driver_for_session(args.role_id, args.state_dir)
    if not drv:
        # idempotent — also remove any stale dir
        shutil.rmtree(session_dir(args.role_id, args.state_dir), ignore_errors=True)
        return 0
    drv.cleanup(args.role_id, args.state_dir)
    return 0


# ============================================================
# CLI
# ============================================================


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="agent-session")
    sub = p.add_subparsers(dest="command", required=True)

    sub.add_parser("doctor", help="health check (read-only)")
    sub.add_parser("list-backends", help="list detected backends, one per line")

    p_describe = sub.add_parser("describe", help="describe a session")
    p_describe.add_argument("--role-id", "--session-id", dest="role_id", required=True)
    p_describe.add_argument("--state-dir")

    p_spawn = sub.add_parser("spawn", help="create a session and run first turn")
    p_spawn.add_argument("--backend", required=True)
    p_spawn.add_argument("--role-id", "--session-id", dest="role_id", required=True)
    p_spawn.add_argument("--prompt-file", required=True)
    p_spawn.add_argument("--model")
    p_spawn.add_argument("--state-dir")
    p_spawn.add_argument("--system-prompt")
    p_spawn.add_argument("--force", action="store_true")
    p_spawn.add_argument("--cwd")
    p_spawn.add_argument("--yolo", action="store_true")

    p_run = sub.add_parser(
        "run",
        help="one-shot, stateless invocation: returns assistant text to stdout",
    )
    p_run.add_argument("--backend", required=True)
    p_run.add_argument("--prompt-file", required=True)
    p_run.add_argument("--model")
    p_run.add_argument("--system-prompt")
    p_run.add_argument("--cwd")
    p_run.add_argument("--yolo", action="store_true")

    p_send = sub.add_parser("send", help="continue an existing session")
    p_send.add_argument("--role-id", "--session-id", dest="role_id", required=True)
    p_send.add_argument("--prompt-file", required=True)
    p_send.add_argument("--state-dir")

    p_status = sub.add_parser(
        "status",
        help="read session state (always synchronous; spawn/send block until done)",
    )
    p_status.add_argument("--role-id", "--session-id", dest="role_id", required=True)
    p_status.add_argument("--state-dir")

    p_output = sub.add_parser("output", help="read assistant message")
    p_output.add_argument("--role-id", "--session-id", dest="role_id", required=True)
    p_output.add_argument("--state-dir")
    p_output.add_argument("--round", type=int)

    p_tldr = sub.add_parser("tldr", help="extract TL;DR + stance as JSON for the latest round")
    p_tldr.add_argument("--role-id", "--session-id", dest="role_id", required=True)
    p_tldr.add_argument("--state-dir")
    p_tldr.add_argument("--round", type=int)

    p_cleanup = sub.add_parser("cleanup", help="close session and remove state")
    p_cleanup.add_argument("--role-id", "--session-id", dest="role_id", required=True)
    p_cleanup.add_argument("--state-dir")

    return p


HANDLERS = {
    "doctor": cmd_doctor,
    "list-backends": cmd_list_backends,
    "describe": cmd_describe,
    "spawn": cmd_spawn,
    "run": cmd_run,
    "send": cmd_send,
    "status": cmd_status,
    "output": cmd_output,
    "tldr": cmd_tldr,
    "cleanup": cmd_cleanup,
}


def main(argv: Optional[list[str]] = None) -> int:
    args = build_parser().parse_args(argv)
    try:
        return HANDLERS[args.command](args)
    except RuntimeError as e:
        print(str(e), file=sys.stderr)
        return 1


if __name__ == "__main__":
    sys.exit(main())
